# ── Core ─────────────────────────────────────────────────────────────
TEMPORALLAYR_API_KEY=your-bootstrap-api-key
TEMPORALLAYR_ADMIN_KEY=your-admin-key
TEMPORALLAYR_TENANT_ID=default
TEMPORALLAYR_DATA_DIR=.temporallayr
TEMPORALLAYR_LOG_LEVEL=INFO

# ── SDK Transport ─────────────────────────────────────────────────────
TEMPORALLAYR_SERVER_URL=http://localhost:8000
TEMPORALLAYR_BATCH_SIZE=100
TEMPORALLAYR_FLUSH_INTERVAL=2.0
TEMPORALLAYR_MAX_RETRIES=3

# ── Rate Limits ───────────────────────────────────────────────────────
TEMPORALLAYR_INGEST_RATE_LIMIT=1000     # req/min per tenant
TEMPORALLAYR_API_RATE_LIMIT=200         # req/min per tenant

# ── ClickHouse Cloud (leave blank to disable analytics) ───────────────
TEMPORALLAYR_CLICKHOUSE_HOST=
TEMPORALLAYR_CLICKHOUSE_PORT=8443
TEMPORALLAYR_CLICKHOUSE_SECURE=true
TEMPORALLAYR_CLICKHOUSE_USER=default
TEMPORALLAYR_CLICKHOUSE_PASSWORD=

# ── OTLP (Phoenix / Jaeger / Grafana Tempo) ──────────────────────────
TEMPORALLAYR_OTLP_ENDPOINT=
TEMPORALLAYR_OTLP_API_KEY=

# ── Retention ────────────────────────────────────────────────────────
TEMPORALLAYR_RETENTION_DAYS=30

# ── Dashboard (build-time for Vite) ──────────────────────────────────
VITE_API_URL=http://localhost:8000
