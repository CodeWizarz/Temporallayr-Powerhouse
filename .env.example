# Core
TEMPORALLAYR_API_KEY=your-bootstrap-key
TEMPORALLAYR_ADMIN_KEY=your-admin-key
TEMPORALLAYR_TENANT_ID=default
TEMPORALLAYR_DATA_DIR=.temporallayr
TEMPORALLAYR_LOG_LEVEL=INFO

# Storage — set POSTGRES_DSN to switch from SQLite automatically
DATABASE_URL=
# preferred, e.g. postgresql://user:pass@ep-xxx.neon.tech/temporallayr?sslmode=require
TEMPORALLAYR_POSTGRES_DSN=
# legacy fallback if DATABASE_URL is not set

# Rate limits
TEMPORALLAYR_INGEST_RATE_LIMIT=1000
TEMPORALLAYR_API_RATE_LIMIT=200

# ClickHouse Cloud (leave blank to disable /analytics endpoints)
TEMPORALLAYR_CLICKHOUSE_HOST=
TEMPORALLAYR_CLICKHOUSE_PORT=8443
TEMPORALLAYR_CLICKHOUSE_SECURE=true
TEMPORALLAYR_CLICKHOUSE_USER=default
TEMPORALLAYR_CLICKHOUSE_PASSWORD=

# ── Redis Queue (Required if Clickhouse backend used) ─────────
TEMPORALLAYR_REDIS_URL=redis://localhost:6379/0
TEMPORALLAYR_QUEUE_BATCH_SIZE=50
TEMPORALLAYR_QUEUE_FLUSH_INTERVAL=2.0

# OTLP export (Phoenix / Jaeger / Grafana Tempo)
TEMPORALLAYR_OTLP_ENDPOINT=
TEMPORALLAYR_OTLP_API_KEY=

# Dashboard (build-time Vite env)
VITE_API_URL=http://localhost:8000
