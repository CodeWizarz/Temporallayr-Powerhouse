{
    "rewrites": [
        {
            "source": "/landing",
            "destination": "/landing.html"
        },
        {
            "source": "/((?!landing\\.html|assets|favicon).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}